//p5.js code for graphic

let distance = 200;
const MAX_DIST = 200;

const sketch = function(p) {
  const AXIOM = 'X';
  const RULES = {
    'X': 'F+[[X]-X]-F[-FX]+X',
    'F': 'FF'
  };
  const MAX_DEPTH = 6;
  const MIN_DEPTH = 0;

  let strings = [];
  let mode = 'grow';
  let growDepth = MIN_DEPTH;
  let witherProgress = 1.0;
  let currentString = '';
  let renderLength = 0;

  const WITHER_SPEED = 0.012;
  const PULSE_SPEED  = 0.012;

  let pulse = 0;
  let pulseDir = 1;
  let lastGrowTime = 0;
  const GROW_INTERVAL = 1000;

  function buildStrings() {
    strings = [];
    let s = AXIOM;
    strings.push(s);
    for (let i = 1; i <= MAX_DEPTH; i++) {
      let next = '';
      for (const ch of s) next += RULES[ch] || ch;
      s = next;
      strings.push(s);
    }
  }

  function isClose() {
    return distance < 50;
  }

  function trunkLength() {
    const s = strings[MAX_DEPTH];
    for (let i = 0; i < s.length; i++) {
      if (s[i] === '[') return i;
    }
    return s.length;
  }

  let minRenderLength = 0;

  p.setup = function() {
    p.createCanvas(500, 500);
    p.angleMode(p.DEGREES);
    buildStrings();
    currentString = strings[MIN_DEPTH];
    renderLength = currentString.length;
    growDepth = MIN_DEPTH;
    witherProgress = 1.0;
    lastGrowTime = p.millis();
    minRenderLength = trunkLength();
  };

  p.draw = function() {
    p.background(17);

    pulse += PULSE_SPEED * pulseDir;
    if (pulse > 1 || pulse < 0) pulseDir *= -1;

    const close = isClose();

    if (close && mode === 'grow') {
      mode = 'wither';
    } else if (!close && mode === 'wither' && witherProgress <= 0.01) {
      mode = 'grow';
      growDepth = MIN_DEPTH;
      witherProgress = 1.0;
      lastGrowTime = p.millis();
    }

    if (mode === 'grow') {
      const now = p.millis();
      if (now - lastGrowTime >= GROW_INTERVAL && growDepth < MAX_DEPTH) {
        growDepth++;
        lastGrowTime = now;
      }
      currentString = strings[growDepth];
      renderLength = currentString.length;
      witherProgress = 1.0;
    }

    if (mode === 'wither') {
      witherProgress = p.max(0, witherProgress - WITHER_SPEED);
      currentString = strings[p.constrain(growDepth, MIN_DEPTH, MAX_DEPTH)];
      const full = currentString.length;
      const minLen = minRenderLength;
      renderLength = p.floor(p.lerp(minLen, full, witherProgress));
    }

    let br, bg, bb;
    if (mode === 'grow') {
      br = 50; bg = 180; bb = 120;
    } else {
      br = 220; bg = p.lerp(0, 80, witherProgress); bb = p.lerp(0, 50, witherProgress);
    }

    const len = p.map(growDepth, MIN_DEPTH, MAX_DEPTH, 28, 4); // shorter segments, same angle
    const angle = 35 + pulse * 1.5;

    p.translate(p.width / 2, p.height - 20);

    let stack = [];
    const chars = currentString.slice(0, renderLength);
    for (const ch of chars) {
      const alpha = p.map(stack.length, 0, 10, 230, 90);
      switch (ch) {
        case 'F':
          p.stroke(br, bg, bb, alpha);
          p.strokeWeight(p.max(0.4, p.map(stack.length, 0, 14, 2.5, 0.4)));
          p.line(0, 0, 0, -len);
          p.translate(0, -len);
          break;
        case '+': p.rotate(angle);  break;
        case '-': p.rotate(-angle); break;
        case '[': stack.push({}); p.push(); break;
        case ']':
          p.pop();
          if (stack.length) stack.pop();
          break;
      }
    }
  };
};

const myP5 = new p5(sketch);

function updateDistance(val) {
  distance = val;
}
